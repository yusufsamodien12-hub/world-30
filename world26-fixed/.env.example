# World26 configuration
#
# Option A (recommended for production): point at a deployed Cloudflare
# Worker proxy that holds the real Mistral API key server-side.
VITE_PROXY_URL=https://your-worker.your-subdomain.workers.dev/v1/chat/completions

# Option B (local development only): call the Mistral API directly.
# Never ship a real key to a static/browser build with this set --
# it would be visible to anyone who opens devtools.
# VITE_PROXY_URL=http://localhost:3001/api/mistral/chat
# MISTRAL_API_KEY=your_mistral_api_key_here
